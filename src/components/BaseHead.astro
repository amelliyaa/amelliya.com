---
import "@styles/global.css";
import { Font } from "astro:assets";

export interface Props {
  title: string;
  description: string;
  image?: string;
  type?: "website" | "article";
  article?: {
    published?: Date;
    modified?: string;
    tags?: string[];
  };
}

const { title, description, image, type = "website", article } = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImageURL = image ? new URL(image, Astro.site) : null;
---

<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />

<title>{title}</title>

<meta name="title" content={title} />
<meta name="description" content={description} />
{
  type === "article" && article && (
    <>
      {article.published && (
        <meta property="article:published_time" content={article.published.toISOString()} />
      )}
      {article.modified && !isNaN(Date.parse(article.modified)) && (
        <meta property="article:modified_time" content={article.modified} />
      )}
      <meta property="article:author" content="Liya Ali" />
      {article.tags && article.tags.map((tag) => <meta property="article:tag" content={tag} />)}
    </>
  )
}
<meta name="generator" content={Astro.generator} />
<meta name="theme-color" content="#cfa3ef" />
<meta name="color-scheme" content="light dark" />

<link rel="canonical" href={canonicalURL} />
<link rel="sitemap" href="/sitemap-index.xml" />
<link rel="apple-touch-icon" sizes="180x180" href="/favicon/apple-touch-icon.png" />
<link rel="icon" type="image/png" sizes="32x32" href="/favicon/favicon-32x32.png" />
<link rel="icon" type="image/png" sizes="16x16" href="/favicon/favicon-16x16.png" />
<link rel="icon" type="image/svg+xml" href="/favicon/favicon.svg" />
<link rel="manifest" href="/site.webmanifest" />

<Font cssVariable="--typeface-display" />
<Font cssVariable="--typeface-body" />
<Font cssVariable="--typeface-workhorse" />

<meta property="og:type" content={type} />
<meta property="og:url" content={canonicalURL} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
{ogImageURL && <meta property="og:image" content={ogImageURL} />}

<meta property="twitter:card" content="summary_large_image" />
<meta property="twitter:url" content={canonicalURL} />
<meta property="twitter:title" content={title} />
<meta property="twitter:description" content={description} />
{ogImageURL && <meta property="twitter:image" content={ogImageURL} />}

<link href="/pagefind/pagefind-component-ui.css" rel="stylesheet" />
<script src="/pagefind/pagefind-component-ui.js" type="module" is:inline></script>

<script
  defer
  src="https://static.cloudflareinsights.com/beacon.min.js"
  data-cf-beacon='{"token": "f1a057855418414d9a6b9ff70f2e24ea"}'
  is:inline></script>

<link rel="expect" blocking="render" href="#the-unexpected" />
