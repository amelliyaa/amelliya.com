---
import OpenIcon from "@icons/open-outline.svg";
const { href } = Astro.props;

// HTML must be a single line to prevent a trailing space from being generated
---

<a href={href} class="_link"
  ><slot />{href.startsWith("https") && <OpenIcon class="_open" aria-hidden={true} />}</a
><style>
  ._link {
    text-decoration: underline;
    border-radius: var(--border-radius-sm);
  }

  ._link:hover,
  ._link:focus {
    color: var(--color-primary);
  }

  ._link:active {
    outline: 2px solid var(--color-selected);
  }

  ._open {
    inline-size: var(--space-xs);
    block-size: var(--space-xs);
    margin-inline-start: 3px;
    transform: translateY(10%);
  }

  @media (prefers-reduced-motion: no-preference) {
    ._link {
      transition: color var(--anim-length-short) ease-in-out;
    }
  }
</style>
