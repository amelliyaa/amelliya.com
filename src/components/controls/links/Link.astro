---
const { href, name } = Astro.props;
---

<a href={href} class="link" aria-label=`Link to ${name}`>
  <slot />
</a>

<style>
  .link {
    text-decoration: underline;
    border-radius: var(--border-radius-sm);
  }

  .link:hover,
  .link:focus {
    color: var(--color-link-bright);
  }

  .link:active {
    outline: 2px solid var(--color-primary-400);
  }

  @media (prefers-reduced-motion: no-preference) {
    .link {
      transition: color var(--anim-length-short) ease-in-out;
    }
  }
</style>
