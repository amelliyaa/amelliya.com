---
const { href, isActive, ...attrs } = Astro.props;
---

<a
  href={href}
  class:list={["menu-link", isActive && "active"]}
  aria-current={isActive && "page"}
  {...attrs}
>
  <slot />
</a>

<style>
  .menu-link {
    display: inline-block;
    position: relative;
    margin: 0;
    border-radius: var(--border-radius-sm);

    font-family: var(--typeface-workhorse);
    font-size: var(--font-size-base);
    font-weight: var(--light);
    color: var(--color-text-light);
  }

  .menu-link::after {
    content: "";
    display: block;
    position: absolute;
    left: 0;
    bottom: -4px;
    block-size: 2px;
    inline-size: 100%;
    background-color: var(--color-selected);
    transform-origin: right;
    transform: scaleX(0) scaleY(1.0001);
  }

  :not(.active).menu-link:hover::after,
  :not(.active).menu-link:focus::after {
    transform-origin: left;
    /* scaleY prevents the height from jumping around causing annoying visual glitches */
    transform: scaleX(1) scaleY(1.0001);
  }

  .active {
    color: var(--color-selected) !important;
  }

  .active::before {
    content: "";
    position: absolute;
    z-index: -1;
    top: 50%;
    left: 50%;
    inline-size: 125%;
    block-size: 150%;
    border-radius: var(--border-radius-sm);
    outline: 2px solid var(--color-selected);
    transform: translate(-50%, -50%);
  }

  :not(.active).menu-link:active {
    outline: 2px solid var(--color-selected);
  }

  .menu-link:hover,
  .menu-link:focus {
    color: var(--color-primary);
  }

  @media (prefers-reduced-motion: no-preference) {
    .menu-link {
      transition: color var(--anim-length-short) ease-in-out;
    }

    .menu-link::after {
      transition: transform var(--anim-length-base) cubic-bezier(0.85, 0, 0.15, 1);
    }
  }
</style>
