---
import { mainNavLinks } from "@components/Header.astro";
import MenuLink from "@components/controls/MenuLink.astro";

const sitemap = [
  ...mainNavLinks,
  {
    path: "/about",
    name: "About",
  },
  {
    path: "/privacy",
    name: "Privacy",
  },
];

const { class: className, ...attrs } = Astro.props;
---

<ul class:list={["_sitemap", className]} id="sitemap" aria-label="Site map" {...attrs}>
  {
    sitemap.map((page) => (
      <li>
        <MenuLink href={page.path}>{page.name}</MenuLink>
      </li>
    ))
  }
</ul>

<style>
  ._sitemap {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-sm) var(--space-lg);
  }

  ._sitemap:nth-last-child(2) {
    grid-column: 2 / 3;
    grid-row: 1;
  }

  ._sitemap:last-child {
    grid-column: 2 / 3;
    grid-row: 2;
  }
</style>
