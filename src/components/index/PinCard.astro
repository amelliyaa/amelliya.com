---
const { project } = Astro.props;
---

<div class="pin-card" data-pin-size={project.data.pinSize}>
  <div class="pin-content">
    <span class="pin-icon" aria-hidden="true"></span>
    <h3 class="pin-heading">
      {project.data.workingTitle}
      <span class="pin-progress">{project.data.progress}%</span>
    </h3>
    <p class="pin-desc">{project.data.description}</p>
  </div>
  <span class="pin-updated">
    Last updated
    {
      new Date(project.data.updated).toLocaleDateString(undefined, {
        year: "numeric",
        month: "short",
        day: "numeric",
      })
    }
  </span>
</div>

<style>
  .pin-card {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    position: relative;
    min-inline-size: 140px;
    aspect-ratio: 1 / 1;
    padding: var(--space-md) var(--space-md) var(--space-sm) var(--space-sm);
    border-radius: var(--border-radius-sm);
    color: var(--color-text-dark);
    background-color: var(--color-accent);
    box-shadow: var(--box-shadow-lg);
  }

  .pin-card:nth-child(odd) {
    background-color: var(--color-accent-dark);
  }

  .pin-icon {
    position: absolute;
    left: 50%;
    top: 12px;
    inline-size: var(--space-2xs-xs);
    border-radius: 50%;
    aspect-ratio: 1 / 1;
    background-color: var(--_pin-board-bg);
    box-shadow: inset 0 -2px 4px rgb(14 13 17 / 45%);
    transform: translateX(-50%);
  }

  .pin-icon::after {
    content: "📌";
    position: absolute;
    left: 2px;
    top: -22px;
    inline-size: var(--space-2xs-xs);
    font-size: var(--font-size-md);
    filter: drop-shadow(0 -2px 8px rgb(14 13 17 / 40%));
  }

  .pin-heading {
    font-size: var(--font-size-md);
    font-weight: var(--medium);
  }

  .pin-desc {
    margin-block: 0 var(--space-2xs);
  }

  .pin-progress,
  .pin-update {
    font-family: var(--typeface-workhorse);
    font-weight: var(--medium);
  }

  .pin-progress {
    padding: var(--space-3xs) var(--space-2xs);
    border-radius: var(--border-radius-lg);
    font-size: var(--font-size-base);
    color: var(--color-text-dark);
    background-color: rgb(250 250 250 / 50%);
  }

  .pin-updated {
    font-size: var(--font-size-sm);
  }

  @media (prefers-reduced-motion: no-preference) {
    .pin-card {
      transition: transform var(--anim-length-short) ease-in-out;
    }

    .pin-card:hover {
      transform: rotate(-4deg);
    }
  }
</style>
