---
const { project } = Astro.props;
---

<div class="pin-card" data-pin-size={project.data.pinSize}>
  <div class="pin-content">
    <h3>
      {project.data.workingTitle}
      <span class="pin-progress">{project.data.progress}%</span>
    </h3>
    <p>{project.data.description}</p>
  </div>
  <span class="pin-updated">
    Last updated
    {
      new Date(project.data.updated).toLocaleDateString(undefined, {
        year: "numeric",
        month: "short",
        day: "numeric",
      })
    }
  </span>
</div>

<style>
  .pin-card {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    position: relative;
    min-inline-size: 150px;
    aspect-ratio: 1 / 1;
    padding: var(--space-md) var(--space-md) var(--space-sm) var(--space-sm);
    border-radius: var(--border-radius-sm);
    color: var(--color-neutral-950);
    background-color: var(--color-pin);
    box-shadow: var(--box-shadow-sm);
  }

  .pin-card::before {
    content: "";
    position: absolute;
    left: 50%;
    top: 12px;
    inline-size: var(--space-xs-sm);
    border-radius: 50%;
    aspect-ratio: 1 / 1;
    background-color: var(--_pin-board-bg);
    box-shadow: inset 0 -2px 4px rgb(14 13 17 / 45%);
    transform: translateX(-50%);
  }

  .pin-card:nth-child(odd) {
    background-color: var(--color-pin-dark);
  }

  .pin-content > h3 {
    font-size: var(--font-size-md);
    font-weight: var(--medium);
  }

  .pin-content > p {
    margin-block: 0 var(--space-2xs);
  }

  .pin-progress,
  .pin-update {
    font-family: var(--typeface-workhorse);
    font-weight: var(--medium);
  }

  .pin-progress {
    padding: var(--space-3xs) var(--space-2xs);
    border-radius: var(--border-radius-lg);
    font-size: var(--font-size-base);
    color: var(--color-neutral-950);
    background-color: rgb(255 255 255 / 50%);
  }

  .pin-updated {
    font-size: var(--font-size-sm);
    color: var(--color-neutral-700);
  }

  @media (prefers-reduced-motion: no-preference) {
    .pin-card {
      transition: transform var(--anim-length-short) ease-in-out;
    }

    .pin-card:hover {
      transform: rotate(-4deg);
    }
  }
</style>
