<style>
  .social-media {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--space-md);
  }

  .social-link {
    display: inline-block;
    color: var(--color-text-light);
  }

  .social-link:hover,
  .social-link:focus {
    color: var(--color-primary);
  }

  .social-icon {
    inline-size: var(--font-size-2xl);
    block-size: var(--font-size-2xl);
  }

  .social-icon:hover,
  .social-icon:focus {
    transform: scale(105%);
  }

  @media (prefers-reduced-motion: no-preference) {
    .social-link {
      transition: color var(--anim-length-base) ease-in-out;
    }

    .social-icon {
      transition: transform var(--anim-length-short) ease-in-out;
    }
  }
</style>
