<style>
  .social-media {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--space-md);
  }

  .social-link {
    color: var(--color-neutral-100);
  }

  .social-link:hover,
  .social-link:focus {
    color: var(--color-complement);
  }

  .social-icon {
    inline-size: var(--font-size-2xl);
    block-size: var(--font-size-2xl);
  }

  .social-icon:hover,
  .social-icon:focus {
    transform: scale(105%);
    filter: drop-shadow(var(--box-shadow-lg));
  }

  @media (prefers-reduced-motion: no-preference) {
    .social-link {
      transition: color var(--anim-length-base) ease-in-out;
    }

    .social-icon {
      transition: transform var(--anim-length-short) ease-in-out;
    }
  }
</style>
