---
import SocialMedia from "./SocialMedia.astro";
import Newsletter from "./Newsletter.astro";
import Sitemap from "./Sitemap.astro";
---

<footer class="site-footer">
  <div class="footer-content">
    <Newsletter class="newsletter" />
    <Sitemap class="sitemap" />

    <div class="social-card">
      <SocialMedia />
    </div>
  </div>

  <div class="copyright">
    <hr />
    <span>Copyright © 2025 amelliya</span>
  </div>
</footer>

<style>
  .site-footer {
    inline-size: 100%;
    min-inline-size: fit-content;
    margin-top: auto;
    border-block-start: 1px solid var(--color-bg-bright);
    background-color: var(--color-bg-dark);
  }

  .footer-content {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    align-items: center;
    gap: var(--space-lg);

    max-inline-size: var(--max-page-width);
    margin: var(--space-sm-md) auto var(--space-md-lg) auto;
    padding-inline: var(--space-sm);
  }

  .sitemap {
    flex: 1 0 auto;
  }

  .newsletter {
    flex: 2 0 fit-content;
  }

  /* Social card */
  .social-card {
    flex: 1 0 auto;

    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-md);

    max-inline-size: 100%;
    padding: var(--space-xs) var(--space-md);
    background-color: var(--color-bg);
    border-radius: var(--border-radius-lg);
    box-shadow: var(--box-shadow-md);
  }

  /* Copyright */
  .copyright {
    padding-inline: var(--space-sm);
    text-align: center;
  }

  .copyright > hr {
    border: thin solid var(--color-bg-bright);
  }

  .copyright > span {
    display: inline-block;
    margin-block: 0.5rem 1rem;
    font-family: var(--typeface-workhorse);
    font-size: var(--font-size-sm);
    font-weight: var(--light);
    color: var(--color-text-faint);
  }
</style>
