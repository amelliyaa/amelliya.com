---
import { mainNavLinks } from "./Header.astro";
import MenuLink from "./controls/links/MenuLink.astro";

const sitemap = [
  ...mainNavLinks,
  {
    path: "/about",
    name: "About",
  },
  {
    path: "/contact",
    name: "Contact",
  },
];

const { class: className, ...attrs } = Astro.props;
---

<ul class={className} id="sitemap" aria-label="Site map" {...attrs}>
  {
    sitemap.map((page) => (
      <li>
        <MenuLink href={page.path}>{page.name}</MenuLink>
      </li>
    ))
  }
</ul>

<style>
  ul {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-sm) var(--space-lg);
  }

  ul:nth-last-child(2) {
    grid-column: 2 / 3;
    grid-row: 1;
  }

  ul:last-child {
    grid-column: 2 / 3;
    grid-row: 2;
  }
</style>
