---
import { mainNavLinks } from "./Navbar.astro";
import MenuLink from "./controls/links/MenuLink.astro";

const sitemap = [
  ...mainNavLinks,
  {
    path: "/about",
    name: "About",
  },
  {
    path: "/contact",
    name: "Contact",
  },
];

const { class: className, ...attrs } = Astro.props;
---

<nav class:list={className} aria-label="Site map" {...attrs}>
  <menu>
    {
      sitemap.map((page) => (
        <li role="none">
          <MenuLink href={page.path}>{page.name}</MenuLink>
        </li>
      ))
    }
  </menu>
</nav>

<style>
  menu {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-sm) var(--space-lg);
  }

  menu:nth-last-child(2) {
    grid-column: 2 / 3;
    grid-row: 1;
  }

  menu:last-child {
    grid-column: 2 / 3;
    grid-row: 2;
  }
</style>
