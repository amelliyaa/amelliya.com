---
import { ImageMetadata } from "astro";
import { Picture } from "astro:assets";

const { href, frontmatter, ...rest } = Astro.props;
const date = new Date(frontmatter.updated).toLocaleDateString(undefined, {
  year: "numeric",
  month: "short",
  day: "numeric",
});

const images = import.meta.glob<{ default: ImageMetadata }>(
  "/src/assets/images/*.{jpeg,jpg,png,gif}",
);
if (!images[frontmatter.thumbnail.imagePath])
  throw new Error(
    `"${frontmatter.thumbnail.imagePath}" does not exist in glob: "src/assets/images/*.{jpeg,jpg,png,gif}"`,
  );
---

<a href={href} class="blog-card" aria-label=`Link to article: ${frontmatter.title}` {...rest}>
  <Picture
    class="post-thumbnail"
    src={images[frontmatter.thumbnail.imagePath]()}
    alt={frontmatter.thumbnail.alt}
  />
  <div class="blog-card-content">
    <div class="post-tags">
      {frontmatter.tags.map((tag: string) => <span class="metadata tag">{tag}</span>)}
    </div>
    <hgroup class="post-info">
      <h3 class="post-title">{frontmatter.title}</h3>
      <p class="post-desc">{frontmatter.description}</p>
    </hgroup>
    <div class="post-date">
      <svg
        xmlns="http://www.w3.org/2000/svg"
        class="ionicon"
        viewBox="0 0 512 512"
        width="20"
        height="20"
        aria-hidden="true"
      >
        <rect
          fill="none"
          stroke="currentColor"
          stroke-linejoin="round"
          stroke-width="32"
          x="48"
          y="80"
          width="416"
          height="384"
          rx="48"
        >
        </rect>
        <path
          fill="none"
          stroke="currentColor"
          stroke-linejoin="round"
          stroke-width="32"
          stroke-linecap="round"
          d="M128 48v32M384 48v32M464 160H48"
        >
        </path>
      </svg>
      <time class="metadata" datetime={frontmatter.updated}>{date}</time>
    </div>
  </div>
</a>

<style>
  .blog-card {
    position: relative;
    display: flex;
    flex-direction: column;
    min-inline-size: 200px;
    border-radius: var(--border-radius-lg);
    border: 1px solid var(--color-accent);
    color: var(--color-text-light);
    background: var(--color-bg-bright);
    box-shadow: var(--box-shadow-md);
    overflow: hidden;
  }

  .blog-card:hover,
  .blog-card:focus {
    transform: translateY(-4px);
    box-shadow: var(--box-shadow-lg);
  }

  .blog-card:hover::after,
  .blog-card:focus::after {
    opacity: 1;
  }

  .blog-card-content {
    display: flex;
    flex-direction: column;
    block-size: 100%;
    padding: var(--space-xs);
  }

  .post-thumbnail {
    aspect-ratio: 3 / 2;
    inline-size: 100%;
    block-size: 100%;
    object-fit: cover;
    box-shadow: var(--box-shadow-lg);
  }

  .post-info {
    flex: 1;
  }

  .post-title {
    margin-block-start: var(--space-2xs);
    color: var(--color-heading);
  }

  .post-desc {
    margin-block: 0 var(--space-xs);
  }

  .metadata {
    font-family: var(--typeface-workhorse);
    font-size: var(--font-size-sm);
  }

  .post-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2xs);
  }

  .tag {
    padding: var(--space-3xs) var(--space-xs);
    border-radius: var(--border-radius-md);
    font-weight: var(--semibold);
    color: var(--color-text-dark);
    background-color: var(--color-secondary);
  }

  .ionicon {
    inline-size: var(--space-xs);
    block-size: var(--space-xs);
    transform: translateY(10%);
    color: var(--color-secondary);
  }

  @media (prefers-reduced-motion: no-preference) {
    .blog-card {
      transition: transform var(--anim-length-short) ease-in-out;
    }
  }
</style>
