---
import BaseLayout from "@layouts/BaseLayout.astro";
import Featured from "@components/index/Featured.astro";
import PinBoard from "@components/index/PinBoard.astro";
import LatestPosts from "@components/index/LatestPosts.astro";

const title = "Home | amelliya";
const description = "My site's homepage";
---

<BaseLayout title={title} description={description}>
  <h1 class="who">Hello, World! I'm <b>Liya</b></h1>
  <Featured />
  <PinBoard />
  <LatestPosts />
</BaseLayout>

<style>
  .who {
    margin-block-end: var(--space-3xl);

    > b {
      color: var(--color-primary);
    }
  }

  @media (prefers-reduced-motion: no-preference) {
    .who {
      animation:
        slide-in 1s cubic-bezier(0.33, 1, 0.68, 1) forwards,
        fade-in 0.6s cubic-bezier(0.12, 0, 0.39, 0) forwards;
    }

    .who::after {
      display: inline-block;
      content: "";
      inline-size: 0.15em;
      block-size: 1.25em;
      margin-inline-start: 0.05em;
      background-color: var(--color-primary);
      transform: translateY(22%);
      animation: blink-caret 0.8s step-end infinite;
    }

    @keyframes blink-caret {
      from,
      to {
        opacity: 1;
      }
      50% {
        opacity: 0;
      }
    }
  }
</style>
