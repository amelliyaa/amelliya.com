---
import BaseLayout from "../layouts/BaseLayout.astro";
import Link from "../components/controls/links/Link.astro";

const title = "About | Jane Doe";
const description = "About Page";

const palette = ["#CFA3EF", "#F8B8D6", "#F8CB82", "#A9AFF3", "#2E243C"];
---

<BaseLayout title={title} description={description}>
  <h1>About</h1>

  <h2>Me</h2>
  <p></p><h2>This website</h2>
  <p>
    Was designed and built by me as a place to document my journey in the world of game development.
    Third party notices for any open source components used are available in the <Link
      href="/credits.txt">credits.txt file</Link
    >.
  </p>

  <h3>Technologies</h3>
  <p>
    <Link href="https://astro.build/">Astro</Link> is my static site generator of choice. The <abbr
      title="HyperText Markup Language">HTML</abbr
    > is housed within <code>.astro</code> component files and styled with scoped <abbr
      title="Cascading Style Sheets">CSS</abbr
    >. A minimal amount of JavaScript is used to provide <Link
      href="https://developer.mozilla.org/en-US/docs/Glossary/Progressive_Enhancement"
      >progressive enhancement</Link
    >. The pretty syntax highlighting on code blocks is handled by the <Link
      href="https://github.com/shikijs/shiki">Shiki</Link
    > library (using the Dracula theme). Blog posts are written in <Link
      href="https://github.com/mdx-js/mdx">MDX</Link
    >.
  </p>

  <h3>Colors</h3>
  <p>
    This is the site's main color palette. You can see all the colors I use with the inspect element
    tool in your browser. They'll be listed under the <code>:root</code>
    selector in the styles pane.
  </p>

  <ul class="palette">
    {
      palette.map((swatch) => (
        <li class="swatch" style={`background-color: ${swatch}`}>
          {swatch}
        </li>
      ))
    }
  </ul>

  <h3>Typography</h3>
  <span class="lead-in">I'm using the following typefaces:</span>
  <dl>
    <dt>
      <Link href="https://fonts.google.com/specimen/Philosopher">Philosopher</Link>:
    </dt>
    <dd>for my logo</dd>
    <dt>
      <Link href="https://fonts.google.com/specimen/Merriweather+Sans">Merriweather Sans</Link>:
    </dt>
    <dd>for headings</dd>
    <dt>
      <Link href="https://fonts.google.com/specimen/Merriweather">Merriweather</Link>:
    </dt>
    <dd>for body copy</dd>
    <dt>
      <Link href="https://fonts.google.com/specimen/Inter">Inter</Link>:
    </dt>
    <dd>for UI elements</dd>
  </dl>

  <p>
    I'm also using a <Link
      href="https://utopia.fyi/type/calculator?c=320,18,1.2,1280,21,1.333,5,2,&s=0.75|0.5|0.25,1.5|2|3|4|6,s-l&g=s,l,xl,12"
      name="my fluid type and space scale">fluid type and space scale</Link
    > from <Link href="https://utopia.fyi/" name="Utopia.fyi">Utopia</Link>. It makes font size and
    spacing scale nicely with your device's screen width.
  </p>

  <h3>Hosting</h3>
  <p>
    The domain name was purchased on <Link
      href="https://www.cloudflare.com/products/registrar/"
      name="Cloudflare Registrar">Cloudflare Registrar</Link
    >. The site itself is hosted on <Link href="https://pages.cloudflare" name="Cloudflare Pages"
      >Cloudflare Pages</Link
    >.
  </p></BaseLayout>

<style>
  :global(.content-grid) {
    --_max-width: var(--max-article-width);
  }

  .palette {
    display: grid;
    margin-block-end: var(--space-md-lg);
    border-radius: var(--border-radius-md);
    outline: 2px solid var(--color-text-light);
    color: var(--color-text-dark);
    background-color: var(--color-text-light);
    box-shadow: var(--box-shadow-md);
    overflow: clip;
  }

  .swatch {
    padding-block: var(--space-xs);
    text-align: center;
    font-size: var(--font-size-base);
    font-family: var(--typeface-workhorse);
    font-weight: var(--medium);
  }

  .swatch:last-child {
    color: var(--color-text-light);
  }

  @media only screen and (min-width: 38rem) {
    .palette {
      grid-auto-flow: column;
    }

    .swatch {
      padding-block: var(--space-xl);
    }
  }
</style>
