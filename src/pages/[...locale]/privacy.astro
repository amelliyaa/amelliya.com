---
import { getEntry, render } from "astro:content";
import { makeI18nStaticPathsGenerator, useTranslations } from "@i18n/utils";
import BaseLayout from "@layouts/BaseLayout.astro";
import Link from "@components/controls/Link.astro";
import LastUpdated from "@components/mdx/unique/LastUpdated.astro";

export const getStaticPaths = makeI18nStaticPathsGenerator();

const page = await getEntry("pages", `${Astro.currentLocale}/privacy`);

if (!page) throw new Error("Could not find about page");

const { Content } = await render(page);
const locale = Astro.currentLocale as string;
const t = useTranslations(locale);
const ogImageUrl = `/open-graph/privacy-${locale}.png`;
---

<BaseLayout
  title={t("privacy.meta.title")}
  description={t("privacy.meta.description")}
  image={ogImageUrl}
>
  <Content components={{ a: Link, LastUpdated }} />
</BaseLayout>

<style>
  :global(.content-grid) {
    --_max-width: var(--max-article-width);
    place-items: center;
    text-align: center;
  }
</style>
