---
import { makeI18nStaticPathsGenerator, useTranslations } from "@i18n/utils";
import BaseLayout from "@layouts/BaseLayout.astro";
import Featured from "@components/index/Featured.astro";
import PinBoard from "@components/index/PinBoard.astro";
import LatestPosts from "@components/index/LatestPosts.astro";

export const getStaticPaths = makeI18nStaticPathsGenerator();

const title = "Home | amelliya";
const description = "My site's homepage";

const locale = Astro.currentLocale as string;
const t = useTranslations(locale);
---

<BaseLayout title={title} description={description}>
  <h1 class="who" set:html={t("homepage.greeting")} />
  <Featured />
  <PinBoard />
  <LatestPosts />
</BaseLayout>

<style>
  .who {
    margin-block-end: var(--space-3xl);

    > b {
      color: var(--color-primary);
    }
  }

  @media (prefers-reduced-motion: no-preference) {
    .who::after {
      display: inline-block;
      content: "";
      inline-size: 0.15em;
      block-size: 1.25em;
      margin-inline-start: 0.05em;
      background-color: var(--color-primary);
      transform: translateY(22%);
      animation: blink-caret 0.8s step-end infinite;
    }

    @keyframes blink-caret {
      from,
      to {
        opacity: 1;
      }
      50% {
        opacity: 0;
      }
    }
  }
</style>
