---
import { getCollection } from "astro:content";
import { GetStaticPaths } from "astro";
import { i18n } from "astro:config/client";
import BlogArchive from "@components/BlogArchive.astro";
import BaseLayout from "@layouts/BaseLayout.astro";

export const getStaticPaths = (async ({ paginate }) => {
  const allPosts = await getCollection("posts");

  return i18n!.locales.flatMap((lang) => {
    const posts = allPosts
      .filter((post) => post.data.locale === lang && post.data.draft !== true)
      .sort((a, b) => b.data.published.valueOf() - a.data.published.valueOf());

    const locale = lang === i18n?.defaultLocale ? undefined : (lang as string);
    const tags = [...new Set(posts.flatMap((post) => post.data.tags))];

    return tags.flatMap((tag) => {
      const taggedPosts = posts.filter((post) => post.data.tags.includes(tag));

      return paginate(taggedPosts, {
        pageSize: 6,
        params: { locale, tag },
        props: { tag },
      });
    });
  });
}) satisfies GetStaticPaths;

const { page, tag } = Astro.props;
const title =
  page.currentPage === 1 ? "Blog | amelliya" : `Blog – Page ${page.currentPage} | amelliya`;
const description = "Blog of amelliya";
---

<BaseLayout title={title + tag} description={description + tag}>
  <BlogArchive page={page} currentTag={tag} />
</BaseLayout>
