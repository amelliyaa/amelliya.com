---
import { getCollection } from "astro:content";
import { GetStaticPaths } from "astro";
import { i18n } from "astro:config/client";
import { useTranslations } from "@i18n/utils.ts";
import BlogArchive from "@components/pages/blog/BlogArchive.astro";
import BaseLayout from "@layouts/BaseLayout.astro";

export const getStaticPaths = (async ({ paginate }) => {
  const allPosts = await getCollection("posts");

  return i18n!.locales.flatMap((lang) => {
    const posts = allPosts
      .filter((post) => post.data.locale === lang && !post.data.draft)
      .sort((a, b) => b.data.published.valueOf() - a.data.published.valueOf());

    const locale = lang === i18n?.defaultLocale ? undefined : (lang as string);
    const tags = [...new Set(posts.flatMap((post) => post.data.tags))];

    return tags.flatMap((tag) => {
      const taggedPosts = posts.filter((post) => post.data.tags.includes(tag));

      return paginate(taggedPosts, {
        pageSize: 12,
        params: { locale, tag },
        props: { tag },
      });
    });
  });
}) satisfies GetStaticPaths;

const { page, tag } = Astro.props;
const locale = Astro.currentLocale as string;
const ogImageUrl = `/open-graph/blog-${locale}.png`;
const t = useTranslations(locale);
---

<BaseLayout
  title={page.currentPage === 1
    ? t("blog.meta.title with tag", { tag: tag })
    : t("blog.meta.title with tag and page", { tag: tag, pageNumber: page.currentPage })}
  description={t("blog.meta.description with tag", { tag: tag })}
  image={ogImageUrl}
>
  <BlogArchive page={page} currentTag={tag} />
</BaseLayout>
