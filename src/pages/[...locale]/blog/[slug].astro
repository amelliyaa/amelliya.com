---
import { type CollectionEntry, getCollection, render } from "astro:content";
import { i18n } from "astro:config/client";
import PostLayout from "@layouts/PostLayout.astro";
import Link from "@components/controls/Link.astro";
import IntroParagraph from "@components/mdx/IntroParagraph.astro";
import Callout from "@components/mdx/Callout.astro";
import SeriesCallout from "@components/mdx/SeriesCallout.astro";
import BlockQuote from "@components/mdx/BlockQuote.astro";
import ImageWrapper from "@components/mdx/ImageWrapper.astro";

interface Props {
  post: CollectionEntry<"posts">;
}

export async function getStaticPaths() {
  const posts = await getCollection("posts");

  return posts.map((post) => {
    const locale = post.data.locale === i18n?.defaultLocale ? undefined : post.data.locale;
    return { params: { locale, slug: post.data.translationId }, props: { post } };
  });
}

const { post } = Astro.props;
const { Content, headings, remarkPluginFrontmatter } = await render(post);

const components = {
  a: Link,
  IntroParagraph,
  Callout,
  SeriesCallout,
  BlockQuote,
  ImageWrapper,
};
---

<PostLayout
  postId={post.id}
  headings={headings}
  frontmatter={{
    ...post.data,
    readingTime: remarkPluginFrontmatter.readingTime,
    modified: remarkPluginFrontmatter.lastModified,
  }}
>
  <Content components={components} />
</PostLayout>
