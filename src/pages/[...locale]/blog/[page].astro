---
import { getCollection } from "astro:content";
import { getRelativeLocaleUrl } from "astro:i18n";
import { GetStaticPaths } from "astro";
import { i18n } from "astro:config/client";
import BaseLayout from "@layouts/BaseLayout.astro";
import BlogCard from "@components/cards/BlogCard.astro";
import Pagination from "@components/controls/Pagination.astro";

export const getStaticPaths = (async ({ paginate }) => {
  const allPosts = await getCollection("posts");

  return i18n!.locales.flatMap((lang) => {
    const posts = allPosts
      .filter((post) => post.data.locale === lang)
      .sort((a, b) => b.data.published.valueOf() - a.data.published.valueOf());
    const locale = lang === i18n?.defaultLocale ? undefined : (lang as string);
    return paginate(posts, { pageSize: 6, params: { locale } });
  });
}) satisfies GetStaticPaths;

const { page } = Astro.props;
const title =
  page.currentPage === 1 ? "Blog | amelliya" : `Blog – Page ${page.currentPage} | amelliya`;
const description = "Blog of amelliya";
const locale = Astro.currentLocale as string;
---

<BaseLayout title={title} description={description}>
  <h1>Blog Archives</h1>
  <div class="archive">
    {
      page.data.map((post) => (
        <BlogCard
          href={getRelativeLocaleUrl(locale, `blog/${post.data.translationId}`)}
          frontmatter={post.data}
        />
      ))
    }
  </div>
  {
    page.lastPage > 1 && (
      <Pagination
        currentPage={page.currentPage}
        lastPage={page.lastPage}
        prevUrl={page.url.prev}
        nextUrl={page.url.next}
      />
    )
  }
</BaseLayout>

<style>
  .archive {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-md-lg);
    margin-block-end: var(--space-sm-md);
  }

  @media only screen and (min-width: 36rem) {
    .archive {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media only screen and (min-width: 62rem) {
    .archive {
      grid-template-columns: 1fr 1fr 1fr;
    }
  }
</style>
