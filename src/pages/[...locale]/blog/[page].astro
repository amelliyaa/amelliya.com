---
import { getCollection } from "astro:content";
import { GetStaticPaths } from "astro";
import { i18n } from "astro:config/client";
import { useTranslations } from "@i18n/utils.ts";
import BlogArchive from "@components/pages/blog/BlogArchive.astro";
import BaseLayout from "@layouts/BaseLayout.astro";

export const getStaticPaths = (async ({ paginate }) => {
  const allPosts = await getCollection("posts");

  return i18n!.locales.flatMap((lang) => {
    const posts = allPosts
      .filter((post) => post.data.locale === lang && !post.data.draft)
      .sort((a, b) => b.data.published.valueOf() - a.data.published.valueOf());
    const locale = lang === i18n?.defaultLocale ? undefined : (lang as string);
    return paginate(posts, { pageSize: 12, params: { locale } });
  });
}) satisfies GetStaticPaths;

const { page } = Astro.props;
const locale = Astro.currentLocale as string;
const ogImageUrl = `/open-graph/blog-${locale}.png`;
const t = useTranslations(locale);
---

<BaseLayout
  title={page.currentPage === 1
    ? t("blog.meta.title")
    : t("blog.meta.title with page", { pageNumber: page.currentPage })}
  description={t("blog.meta.description")}
  image={ogImageUrl}
>
  <BlogArchive page={page} />
</BaseLayout>
