---
import { makeI18nStaticPathsGenerator, useTranslations } from "@i18n/utils";
import { getEntry, render } from "astro:content";
import BaseLayout from "@layouts/BaseLayout.astro";
import Link from "@components/controls/Link.astro";

export const getStaticPaths = makeI18nStaticPathsGenerator();

const page = await getEntry("pages", `${Astro.currentLocale}/about`);

if (!page) throw new Error("Could not find about page");

const { Content } = await render(page);
const locale = Astro.currentLocale as string;
const ogImageUrl = `/open-graph/about-${locale}.png`;
const t = useTranslations(locale);
---

<BaseLayout
  title={t("about.meta.title")}
  description={t("about.meta.description")}
  image={ogImageUrl}
>
  <Content components={{ a: Link }} />
</BaseLayout>

<style>
  :global(.content-grid) {
    --_max-width: var(--max-article-width);
  }
</style>
