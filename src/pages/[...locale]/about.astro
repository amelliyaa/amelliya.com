---
import { makeI18nStaticPathsGenerator } from "@i18n/utils";
import { getEntry, render } from "astro:content";
import BaseLayout from "@layouts/BaseLayout.astro";
import Palette from "@components/about/Palette.astro";

export const getStaticPaths = makeI18nStaticPathsGenerator();

const page = await getEntry("pages", `${Astro.currentLocale}/about`);
if (!page) throw new Error("Could not find about page");
const { Content } = await render(page);
---

<BaseLayout title={page.data.title} description={page.data.description}>
  <Content components={Palette} />
</BaseLayout>

<style>
  :global(.content-grid) {
    --_max-width: var(--max-article-width);
  }
</style>
