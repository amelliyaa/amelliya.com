---
import BaseLayout from "../layouts/BaseLayout.astro";
import SearchBar from "../components/SearchBar.astro";
import Link from "../components/controls/links/Link.astro";

const title = "404 Not Found | amelliya";
const description = "My site's homepage";
---

<BaseLayout title={title} description={description}>
  <div class="not-found">
    <h1 class="error-code">404</h1>
    <h2 class="error-msg">Page Not Found <span aria-hidden="true">🥲</span></h2>
    <p class="hint">
      Sorry! But the page you're looking for doesn't seem to exist.
      <Link href="/" name="Home">Go back home</Link>
      or try searching for it instead.
    </p>

    <SearchBar />
  </div>
</BaseLayout>

<style>
  .not-found {
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    block-size: 100%;
    text-align: center;
  }

  .error-code {
    font-size: var(--font-size-3xl);
    font-weight: var(--black);
  }

  .hint {
    max-inline-size: var(--max-article-width);
  }
</style>
