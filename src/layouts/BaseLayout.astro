---
import type { ComponentProps } from "astro/types";
import BaseHead from "@components/layouts/BaseHead.astro";
import Header from "@components/layouts/Header.astro";
import Footer from "@components/layouts/Footer.astro";
import MainContentLink from "@components/controls/MainContentLink.astro";

type Props = ComponentProps<typeof BaseHead> & {
  fluid?: boolean;
};

const { title, description, fluid, ...rest } = Astro.props;
const locale = Astro.currentLocale;
---

<html lang={locale}>
  <head>
    <BaseHead title={title + " | amelliya"} description={description} {...rest} />
    <slot name="schema-markup" />
  </head>
  <body>
    <MainContentLink />
    <Header />
    <main id="main-content" class:list={[{ "content-grid": !fluid }]}>
      <slot />
    </main>
    <Footer />
  </body>
</html>
