---
import type { ComponentProps } from "astro/types";
import BaseHead from "@components/BaseHead.astro";
import MainContentLink from "@components/controls/MainContentLink.astro";
import Header from "@components/Header.astro";
import Footer from "@components/Footer.astro";

type Props = ComponentProps<typeof BaseHead>;

const { title, description, ...rest } = Astro.props;
const locale = Astro.currentLocale;
---

<html lang={locale}>
  <head>
    <BaseHead title={title + " | amelliya"} description={description} {...rest} />
    <slot name="schema-markup" />
  </head>
  <body>
    <MainContentLink />
    <Header />
    <main id="main-content" class="content-grid">
      <slot />
    </main>
    <Footer />
  </body>
</html>
