---
import type { ComponentProps } from "astro/types";
import Head from "@components/Head.astro";
import MainContentLink from "@components/controls/MainContentLink.astro";
import Header from "@components/Header.astro";
import Footer from "@components/Footer.astro";

type Props = ComponentProps<typeof Head>;

const { title, description, ...rest } = Astro.props;
const locale = Astro.currentLocale;
---

<html lang={locale}>
  <Head title={title + " | amelliya"} description={description} {...rest} />
  <body>
    <MainContentLink />
    <Header />
    <main id="main-content" class="content-grid">
      <slot />
    </main>
    <Footer />
  </body>
</html>
