---
import { type ComponentProps } from "astro/types";
import { type CollectionEntry } from "astro:content";
import { type MarkdownHeading } from "astro";
import BaseLayout from "@layouts/BaseLayout.astro";
import BaseHead from "@components/BaseHead.astro";
import Article from "@components/schema-markup/Article.astro";
import ArticleHeader from "@components/layouts/ArticleHeader.astro";
import ArticleFooter from "@components/layouts/ArticleFooter.astro";
import ReadingProgress from "@components/layouts/ReadingProgress.astro";
import TableOfContents from "@components/layouts/TableOfContents.astro";

interface Props extends Omit<ComponentProps<typeof BaseHead>, "title" | "description"> {
  postId: string;
  frontmatter: CollectionEntry<"posts">["data"] & {
    readingTime: string;
    modified: string;
  };
  headings: MarkdownHeading[];
}

const { postId, frontmatter, headings } = Astro.props;
const locale = Astro.currentLocale;
const ogImageUrl = `post-${locale}-${frontmatter.translationId}`;
const articleMetadata = {
  published: frontmatter.published,
  modified: frontmatter.modified,
  tags: frontmatter.tags,
};
---

<BaseLayout
  title={frontmatter.title}
  description={frontmatter.description}
  type="article"
  image={ogImageUrl}
  article={articleMetadata}
  fluid
>
  <Article
    slot="schema-markup"
    headline={frontmatter.title}
    datePublished={frontmatter.published}
    dateModified={frontmatter.modified}
    description={frontmatter.description}
  />
  <ReadingProgress />
  <article class="article-grid">
    <ArticleHeader
      title={frontmatter.title}
      published={frontmatter.published}
      modified={frontmatter.modified}
      description={frontmatter.description}
      readingTime={frontmatter.readingTime}
      tags={frontmatter.tags}
    />
    <TableOfContents headings={headings} />
    <slot />
    <ArticleFooter postId={postId} tags={frontmatter.tags} />
  </article>
</BaseLayout>

<style>
  .sidebar-left {
    display: block;
    text-wrap: wrap;
  }
</style>
