/*
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Referrer-Policy: strict-origin-when-cross-origin
  Cross-Origin-Opener-Policy: same-origin
  Content-Security-Policy: object-src 'none'; base-uri 'none'; connect-src 'self' https://cloudflareinsights.com; worker-src 'self' blob:; script-src 'self' 'unsafe-inline' 'inline-speculation-rules' 'wasm-unsafe-eval' https://static.cloudflareinsights.com; style-src 'self' 'unsafe-inline'; frame-ancestors 'none';
  Speculation-Rules: "/speculation-rules.json"

/speculation-rules.json
  Content-Type: application/speculationrules+json