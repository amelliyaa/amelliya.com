{
  "name": "amelliya.com",
  "author": "",
  "description": "",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro check && astro build && npx -y pagefind --site dist/client",
    "preview": "astro preview",
    "astro": "astro",
    "test:html": "html-validate \"dist/client/**/*.html\"",
    "test:links": "linkinator ./dist/client --recurse --skip \"https://amelliya.com\"",
    "test:a11y": "pa11y-ci --sitemap http://localhost:4321/sitemap-index.xml --sitemap-find https://www.amelliya.com --sitemap-replace http://localhost:4321",
    "test:all": "npm run test:html && npm run test:links && npm run test:a11y"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/cloudflare": "^13.5.5",
    "@astrojs/markdown-remark": "^7.2.0",
    "@astrojs/mdx": "^6.0.3",
    "@astrojs/sitemap": "^3.7.3",
    "@expressive-code/plugin-line-numbers": "^0.43.1",
    "astro": "https://pkg.pr.new/astro@b57dafd",
    "astro-expressive-code": "^0.43.1",
    "astro-og-canvas": "^0.11.1",
    "html-validate": "^11.4.0",
    "linkinator": "^7.6.1",
    "mdast-util-to-string": "^4.0.0",
    "pa11y-ci": "^4.1.1",
    "reading-time": "^1.5.0",
    "rehype-autolink-headings": "^7.1.0",
    "yaml": "^2.8.0"
  },
  "devDependencies": {
    "prettier": "^3.4.2",
    "prettier-plugin-astro": "^0.14.1"
  }
}
